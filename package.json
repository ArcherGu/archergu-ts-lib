{
  "name": "archergu-ts-lib",
  "version": "0.0.0",
  "packageManager": "pnpm@10.33.2",
  "description": "Archer's typescript library template",
  "author": "ArcherGu",
  "license": "MIT",
  "repository": {
    "url": "https://github.com/ArcherGu/archergu-ts-lib.git"
  },
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsdown",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "test": "vitest run",
    "prepublishOnly": "npm run build"
  },
  "devDependencies": {
    "@lightwing/eslint-config": "^1.0.151",
    "@types/node": "^25.5.0",
    "conventional-changelog-cli": "^5.0.0",
    "eslint": "^10.1.0",
    "lint-staged": "^16.4.0",
    "simple-git-hooks": "^2.13.1",
    "tsdown": "^0.21.7",
    "typescript": "^6.0.2",
    "vitest": "^4.1.2"
  },
  "simple-git-hooks": {
    "pre-commit": "npx lint-staged"
  },
  "lint-staged": {
    "*.{js,ts,tsx,vue,md,json,yml}": [
      "eslint --fix"
    ]
  }
}
